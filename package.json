    "iconThemes": [
      {
        "id": "powerbuilder-icons",
        "label": "PowerBuilder Icons",
        "path": "./icons/powerbuilder-icons.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "powerbuilderObjectExplorer",
          "name": "%view.objectExplorer.name%",
          "icon": "icons/files/application.svg",
          "when": "workspaceFolderCount != 0"
        },
        {
          "id": "powerbuilderCurrentObjectContext",
          "name": "%view.currentObjectContext.name%",
          "icon": "icons/files/userobject.svg",
          "when": "workspaceFolderCount != 0"
        },
        {
          "id": "powerbuilderDiagnosticsExplainability",
          "name": "%view.diagnosticsExplainability.name%",
          "icon": "icons/files/structure.svg",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "powerbuilder.focusCurrentObjectContextPanel",
          "when": "view == powerbuilderCurrentObjectContext",
          "group": "navigation@1"
        },
        {
          "command": "powerbuilder.refreshCurrentObjectContextPanel",
          "when": "view == powerbuilderCurrentObjectContext",
          "group": "navigation@2"
        },
        {
          "command": "powerbuilder.focusDiagnosticsExplainabilityPanel",
          "when": "view == powerbuilderDiagnosticsExplainability",
          "group": "navigation@1"
        },
        {
          "command": "powerbuilder.refreshDiagnosticsExplainabilityPanel",
          "when": "view == powerbuilderDiagnosticsExplainability",
          "group": "navigation@2"
        },
        {
          "command": "powerbuilder.focusObjectExplorerOnCurrentProject",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@1"
        },
        {
          "command": "powerbuilder.focusObjectExplorerOnCurrentFile",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@2"
        },
        {
          "command": "powerbuilder.clearObjectExplorerFocus",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@3"
        },
        {
          "command": "powerbuilder.refreshObjectExplorer",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "powerbuilder.openCurrentObjectContextLocation",
          "when": "view == powerbuilderCurrentObjectContext && viewItem == currentObjectContext.item",
          "group": "inline"
        },
        {
          "command": "powerbuilder.openDiagnosticsExplainabilityLocation",
          "when": "view == powerbuilderDiagnosticsExplainability && viewItem == diagnosticsExplainability.item",
          "group": "inline"
        },
        {
          "command": "powerbuilder.openObjectExplorerObject",
          "when": "view == powerbuilderObjectExplorer && viewItem == powerbuilderObjectExplorer.object",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "VSC PowerSyntax",
      "properties": {
        "vscPowerSyntax.profile": {
          "type": "string",
          "enum": [
            "fast",
            "balanced",
            "deep-analysis",
            "legacy-orca",
            "ci-support",
            "support-safe"
          ],
          "default": "balanced",
          "description": "%config.profile.description%"
        },
        "vscPowerSyntax.progress.show": {
          "type": "boolean",
          "default": true,
          "description": "%config.progress.show.description%"
        },
        "vscPowerSyntax.languageServices.documentationLocale": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "es"
          ],
          "default": "auto",
          "description": "%config.languageServices.documentationLocale.description%"
        },
        "vscPowerSyntax.build.pbAutoBuildPath": {
          "type": "string",
          "default": "",
          "description": "%config.build.pbAutoBuildPath.description%"
        },
        "vscPowerSyntax.legacy.orcaPath": {
          "type": "string",
          "default": "",
          "description": "%config.legacy.orcaPath.description%"
        },
        "vscPowerSyntax.legacy.orcaSessionDll": {
          "type": "string",
          "default": "",
          "description": "%config.legacy.orcaSessionDll.description%"
        },
        "vscPowerSyntax.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.formatting.enabled.description%"
        },
        "vscPowerSyntax.formatting.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "%config.formatting.formatOnSave.description%"
        },
        "vscPowerSyntax.formatting.keywordCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "%config.formatting.keywordCase.description%"
        },
        "vscPowerSyntax.formatting.statementCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "%config.formatting.statementCase.description%"
        },
        "vscPowerSyntax.formatting.typeCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "%config.formatting.typeCase.description%"
        },
        "vscPowerSyntax.formatting.eventKeywordCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "%config.formatting.eventKeywordCase.description%"
        },
        "vscPowerSyntax.formatting.indentStyle": {
          "type": "string",
          "enum": [
            "spaces",
            "tabs"
          ],
          "default": "spaces",
          "description": "%config.formatting.indentStyle.description%"
        },
        "vscPowerSyntax.formatting.indentSize": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "%config.formatting.indentSize.description%"
        },
        "vscPowerSyntax.formatting.maxDocumentChars": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "%config.formatting.maxDocumentChars.description%"
        },
        "vscPowerSyntax.formatting.maxDocumentLines": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "description": "%config.formatting.maxDocumentLines.description%"
        },
        "vscPowerSyntax.formatting.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "%config.formatting.trimTrailingWhitespace.description%"
        },
        "vscPowerSyntax.formatting.spaceAfterComma": {
          "type": "boolean",
          "default": true,
          "description": "%config.formatting.spaceAfterComma.description%"
        },
        "vscPowerSyntax.formatting.spaceAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "%config.formatting.spaceAroundOperators.description%"
        },
        "vscPowerSyntax.formatting.normalizeBlankLines": {
          "type": "string",
          "enum": [
            "preserve",
            "compact"
          ],
          "default": "preserve",
          "description": "%config.formatting.normalizeBlankLines.description%"
        }
      }
    }
  },
  "activationEvents": [],
  "files": [
    "dist/**",
    "syntaxes/**",
    "icons/**",
    "language-configuration.json",
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true});require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('.dist',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run compile",
    "bundle": "node ./tools/esbuild.mjs --production",
    "bundle:watch": "node ./tools/esbuild.mjs --watch",
    "build:test": "tsc -b && npm run bundle && tsc -p tsconfig.test.json",
    "migrate:catalog-localization-target-ids": "npm run compile && node ./scripts/migrate_catalog_localization_target_ids.cjs",
    "report:catalog-consistency": "npm run compile && node ./scripts/generate_catalog_consistency_report.cjs",
    "verify:catalog-coverage": "npm run compile && node ./tools/verify-catalog-coverage.cjs",
    "report:catalog-localization": "npm run compile && node ./scripts/generate_catalog_localization_report.cjs",
    "test": "npm run build:test && vscode-test --label smoke --label unit --label integration",
    "test:smoke": "npm run build:test && vscode-test --label smoke",
    "test:unit": "npm run build:test && vscode-test --label unit",
    "test:integration": "npm run build:test && vscode-test --label integration",
    "test:performance": "npm run build:test && vscode-test --label performance",
    "test:architecture:metrics": "node ./tools/run-architecture-hotspot-guard.mjs",
    "test:architecture:rapid": "node ./tools/run-architecture-rapid-gate.mjs",
    "test:docs:drift": "node ./tools/docs-drift-audit.cjs",
    "test:performance:gate": "node ./tools/run-performance-budget-gate.mjs",
    "test:performance:soak": "node ./tools/run-session-stability-soak.mjs",
    "test:smoke:installed-vsix": "vscode-test --label smoke-installed --grep \"la extensión se activa en menos de 500ms\"",
    "package:vsix": "npm run bundle && node -e \"require('fs').mkdirSync('.dist',{recursive:true})\" && vsce package --no-yarn --out ./.dist/vsc-powersyntax.vsix",
    "package:vsix:list": "vsce ls --no-yarn",
    "verify:vsix-contents": "node ./tools/verify-vsix-contents.mjs",
    "release:summary": "node ./tools/release-readiness-summary.mjs",
    "release:verify": "npm test && npm run test:architecture:rapid && npm run test:docs:drift && npm run test:performance:gate && npm run verify:catalog-coverage && npm run package:vsix && npm run verify:vsix-contents && npm run test:smoke:installed-vsix && npm run release:summary"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
