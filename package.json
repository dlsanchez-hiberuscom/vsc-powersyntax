    "iconThemes": [
      {
        "id": "powerbuilder-icons",
        "label": "PowerBuilder Icons",
        "path": "./icons/powerbuilder-icons.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "powerbuilderObjectExplorer",
          "name": "PowerBuilder Object Explorer",
          "when": "workspaceFolderCount != 0"
        },
        {
          "id": "powerbuilderCurrentObjectContext",
          "name": "Current Object Context",
          "when": "workspaceFolderCount != 0"
        },
        {
          "id": "powerbuilderDiagnosticsExplainability",
          "name": "Diagnostics Explainability",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscPowerSyntax.focusCurrentObjectContextPanel",
          "when": "view == powerbuilderCurrentObjectContext",
          "group": "navigation@1"
        },
        {
          "command": "vscPowerSyntax.refreshCurrentObjectContextPanel",
          "when": "view == powerbuilderCurrentObjectContext",
          "group": "navigation@2"
        },
        {
          "command": "vscPowerSyntax.focusDiagnosticsExplainabilityPanel",
          "when": "view == powerbuilderDiagnosticsExplainability",
          "group": "navigation@1"
        },
        {
          "command": "vscPowerSyntax.refreshDiagnosticsExplainabilityPanel",
          "when": "view == powerbuilderDiagnosticsExplainability",
          "group": "navigation@2"
        },
        {
          "command": "vscPowerSyntax.focusObjectExplorerOnCurrentProject",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@1"
        },
        {
          "command": "vscPowerSyntax.focusObjectExplorerOnCurrentFile",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@2"
        },
        {
          "command": "vscPowerSyntax.clearObjectExplorerFocus",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@3"
        },
        {
          "command": "vscPowerSyntax.refreshObjectExplorer",
          "when": "view == powerbuilderObjectExplorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "vscPowerSyntax.openCurrentObjectContextLocation",
          "when": "view == powerbuilderCurrentObjectContext && viewItem == currentObjectContext.item",
          "group": "inline"
        },
        {
          "command": "vscPowerSyntax.openDiagnosticsExplainabilityLocation",
          "when": "view == powerbuilderDiagnosticsExplainability && viewItem == diagnosticsExplainability.item",
          "group": "inline"
        },
        {
          "command": "vscPowerSyntax.openObjectExplorerObject",
          "when": "view == powerbuilderObjectExplorer && viewItem == powerbuilderObjectExplorer.object",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "VSC PowerSyntax",
      "properties": {
        "vscPowerSyntax.profile": {
          "type": "string",
          "enum": [
            "fast",
            "balanced",
            "deep-analysis",
            "legacy-orca",
            "ci-support",
            "support-safe"
          ],
          "default": "balanced",
          "description": "Perfil gobernado del producto. Expone los presets corporativos fast, balanced, deep-analysis, legacy-orca, ci-support y support-safe como baseline defendible para settings críticos del cliente."
        },
        "vscPowerSyntax.progress.show": {
          "type": "boolean",
          "default": true,
          "description": "Mostrar el indicador de progreso de indexación en la barra de estado."
        },
        "vscPowerSyntax.languageServices.documentationLocale": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "es"
          ],
          "default": "auto",
          "description": "Locale de la documentación visible en hover, completion y signatureHelp. auto usa el idioma de VS Code cuando sea compatible y cae a inglés en el resto."
        },
        "vscPowerSyntax.build.pbAutoBuildPath": {
          "type": "string",
          "default": "",
          "description": "Ruta opcional a PBAutoBuild250.exe. Si queda vacía, el cliente probará PB_AUTOBUILD_PATH y candidatos instalados por defecto."
        },
        "vscPowerSyntax.legacy.orcaPath": {
          "type": "string",
          "default": "",
          "description": "Ruta explícita al ejecutable ORCA legacy. Si queda vacía, el cliente probará PB_ORCA_PATH sin autodetección difusa por rutas instaladas."
        },
        "vscPowerSyntax.legacy.orcaSessionDll": {
          "type": "string",
          "default": "",
          "description": "DLL de sesión ORCA para export a staging. Si queda vacía, el cliente probará PB_ORCA_DLL y caerá en pborc250.dll como valor por defecto para PowerBuilder 2025."
        },
        "vscPowerSyntax.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar el formatter conservador para documentos PowerBuilder compatibles."
        },
        "vscPowerSyntax.formatting.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Aplicar el formatter propio al guardar documentos PowerBuilder compatibles."
        },
        "vscPowerSyntax.formatting.keywordCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "Case base para keywords PowerBuilder cuando no exista una opción más específica."
        },
        "vscPowerSyntax.formatting.statementCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "Case para keywords ejecutables como IF, ELSE, RETURN o END IF."
        },
        "vscPowerSyntax.formatting.typeCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "Case para bloques estructurales como GLOBAL TYPE, FORWARD PROTOTYPES o END TYPE."
        },
        "vscPowerSyntax.formatting.eventKeywordCase": {
          "type": "string",
          "enum": [
            "preserve",
            "upper",
            "lower"
          ],
          "default": "preserve",
          "description": "Case para EVENT/ON y sus cierres."
        },
        "vscPowerSyntax.formatting.indentStyle": {
          "type": "string",
          "enum": [
            "spaces",
            "tabs"
          ],
          "default": "spaces",
          "description": "Estilo de indentación del formatter conservador."
        },
        "vscPowerSyntax.formatting.indentSize": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Tamaño de indentación cuando se usan espacios."
        },
        "vscPowerSyntax.formatting.maxDocumentChars": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "Presupuesto máximo de caracteres para ejecutar el formatter. Usa 0 para desactivar este límite."
        },
        "vscPowerSyntax.formatting.maxDocumentLines": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "description": "Presupuesto máximo de líneas para ejecutar el formatter. Usa 0 para desactivar este límite."
        },
        "vscPowerSyntax.formatting.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "Recortar espacios al final de línea cuando el formatter aplica cambios."
        },
        "vscPowerSyntax.formatting.spaceAfterComma": {
          "type": "boolean",
          "default": true,
          "description": "Normalizar un único espacio tras cada coma fuera de strings y comentarios."
        },
        "vscPowerSyntax.formatting.spaceAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "Normalizar espacios alrededor de operadores relacionales y de asignación conservadores."
        },
        "vscPowerSyntax.formatting.normalizeBlankLines": {
          "type": "string",
          "enum": [
            "preserve",
            "compact"
          ],
          "default": "preserve",
          "description": "Preservar o compactar líneas en blanco consecutivas durante el formateo."
        }
      }
    }
  },
  "activationEvents": [],
  "files": [
    "out/client/**",
    "out/server/**",
    "out/shared/**",
    "syntaxes/**",
    "icons/**",
    "language-configuration.json",
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run compile",
    "build:test": "tsc -b && tsc -p tsconfig.test.json",
    "migrate:catalog-localization-target-ids": "npm run compile && node ./scripts/migrate_catalog_localization_target_ids.cjs",
    "report:catalog-localization": "npm run compile && node ./scripts/generate_catalog_localization_report.cjs",
    "test": "npm run build:test && vscode-test --label smoke --label unit --label integration",
    "test:smoke": "npm run build:test && vscode-test --label smoke",
    "test:unit": "npm run build:test && vscode-test --label unit",
    "test:integration": "npm run build:test && vscode-test --label integration",
    "test:performance": "npm run build:test && vscode-test --label performance",
    "test:architecture:metrics": "node ./tools/run-architecture-hotspot-guard.mjs",
    "test:architecture:rapid": "node ./tools/run-architecture-rapid-gate.mjs",
    "test:performance:gate": "node ./tools/run-performance-budget-gate.mjs",
    "test:performance:soak": "node ./tools/run-session-stability-soak.mjs",
    "package:vsix": "node -e \"require('fs').mkdirSync('.dist',{recursive:true})\" && vsce package --no-yarn --out ./.dist/vsc-powersyntax.vsix",
    "package:vsix:list": "vsce ls --no-yarn",
    "release:verify": "npm test && npm run test:performance:gate && npm run package:vsix"
