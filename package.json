{
  "name": "vsc-powersyntax",
  "displayName": "VSC PowerSyntax",
  "description": "Extensión para PowerBuilder y PowerScript con cliente ligero y servidor LSP separado.",
  "version": "0.1.0",
  "publisher": "lopez",
  "author": "David Lopez",
  "license": "MIT",
  "main": "./out/client/extension.js",
  "homepage": "https://github.com/dlsanchez-hiberuscom/vsc-powersyntax#readme",
  "bugs": {
    "url": "https://github.com/dlsanchez-hiberuscom/vsc-powersyntax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dlsanchez-hiberuscom/vsc-powersyntax.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false
    },
    "untrustedWorkspaces": {
      "supported": "limited"
    }
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "powerbuilder",
    "powerscript",
    "pb",
    "appeon",
    "lsp"
  ],
  "icon": "icons/powerbuilder.png",
  "contributes": {
    "languages": [
      {
        "id": "powerbuilder",
        "aliases": ["PowerBuilder", "PowerScript", "pb"],
        "extensions": [".srj", ".srq", ".pbt", ".pbw", ".pbl"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/powerbuilder.png", "light": "./icons/powerbuilder.png" }
      },
      {
        "id": "powerbuilder-window",
        "extensions": [".srw"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/window.svg", "light": "./icons/files/window.svg" }
      },
      {
        "id": "powerbuilder-datawindow",
        "extensions": [".srd"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/datawindow.svg", "light": "./icons/files/datawindow.svg" }
      },
      {
        "id": "powerbuilder-userobject",
        "extensions": [".sru"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/userobject.svg", "light": "./icons/files/userobject.svg" }
      },
      {
        "id": "powerbuilder-function",
        "extensions": [".srf"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/function.svg", "light": "./icons/files/function.svg" }
      },
      {
        "id": "powerbuilder-menu",
        "extensions": [".srm"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/menu.svg", "light": "./icons/files/menu.svg" }
      },
      {
        "id": "powerbuilder-application",
        "extensions": [".sra"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/application.svg", "light": "./icons/files/application.svg" }
      },
      {
        "id": "powerbuilder-structure",
        "extensions": [".srs"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/structure.svg", "light": "./icons/files/structure.svg" }
      },
      {
        "id": "powerbuilder-pipeline",
        "extensions": [".srp"],
        "configuration": "./language-configuration.json",
        "icon": { "dark": "./icons/files/pipeline.svg", "light": "./icons/files/pipeline.svg" }
      }
    ],
    "grammars": [
      {
        "language": "powerbuilder",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-window",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-datawindow",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-userobject",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-function",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-menu",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-application",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-structure",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "language": "powerbuilder-pipeline",
        "scopeName": "source.powerbuilder",
        "path": "./syntaxes/powerbuilder.tmLanguage.json"
      },
      {
        "scopeName": "markdown.powerbuilder.codeblock",
        "path": "./syntaxes/powerbuilder.markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.powerbuilder": "powerbuilder"
        }
      }
    ],
    "commands": [
      {
        "command": "vscPowerSyntax.restartServer",
        "title": "PowerSyntax: Reiniciar Servidor de Lenguaje",
        "category": "VSC PowerSyntax"
      }
    ],
    "iconThemes": [
      {
        "id": "powerbuilder-icons",
        "label": "PowerBuilder Icons",
        "path": "./icons/powerbuilder-icons.json"
      }
    ]
  },
  "activationEvents": [ ],
  "files": [
    "out/**",
    "syntaxes/**",
    "icons/**",
    "language-configuration.json",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run compile",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && vscode-test --label smoke --label unit --label integration",
    "test:smoke": "npm run build:test && vscode-test --label smoke",
    "test:unit": "npm run build:test && vscode-test --label unit",
    "test:integration": "npm run build:test && vscode-test --label integration",
    "test:performance": "npm run build:test && vscode-test --label performance"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.7.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.2"
  }
}
