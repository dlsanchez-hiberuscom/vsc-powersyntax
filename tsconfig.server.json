{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src/server",
    "outDir": "out/server",
    "types": [
      "node"
    ],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "out/.tsbuildinfo/server.tsbuildinfo"
  },
  "include": [
    "src/server/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ]
}