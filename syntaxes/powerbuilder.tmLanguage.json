{
  "name": "PowerBuilder",
  "scopeName": "source.powerbuilder",
  "fileTypes": [
    "sru",
    "srw",
    "srm",
    "sra",
    "srs",
    "srf",
    "srd",
    "srp",
    "srj",
    "srq"
  ],
  "firstLineMatch": "^((HA)?(?=\\$)|forward)",
  "patterns": [
    { "include": "#headers" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#sql-block" },
    { "include": "#forward-prototypes-section" },
    { "include": "#prototypes-section" },
    { "include": "#variables-section" },
    { "include": "#forward-section" },
    { "include": "#type-declaration" },
    { "include": "#on-declaration" },
    { "include": "#event-declaration" },
    { "include": "#function-declaration" },
    { "include": "#global-object-declaration" },
    { "include": "#variable-declaration" },
    { "include": "#constants" },
    { "include": "#literals" },
    { "include": "#datatypes" },
    { "include": "#pronouns" },
    { "include": "#access-modifiers" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#sql-keywords" },
    { "include": "#reserved-other" },
    { "include": "#operators" },
    { "include": "#enumerated-literal" },
    { "include": "#support-functions" },
    { "include": "#ancestor-function-call" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#labels" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "headers": {
      "patterns": [
        {
          "name": "meta.header.powerbuilder",
          "begin": "\\A(HA)?(?=\\$)",
          "end": "^(?!\\$)",
          "patterns": [
            {
              "name": "meta.header.line.powerbuilder",
              "match": "(\\$)([^$\\r\\n]*)(\\$)(.*)$",
              "captures": {
                "1": {
                  "name": "punctuation.definition.header.powerbuilder"
                },
                "2": {
                  "name": "entity.other.header.key.powerbuilder"
                },
                "3": {
                  "name": "punctuation.definition.header.powerbuilder"
                },
                "4": {
                  "name": "string.unquoted.header.value.powerbuilder"
                }
              }
            }
          ]
        }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.powerbuilder",
          "match": "//.*$"
        },
        {
          "name": "comment.block.powerbuilder",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.powerbuilder"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.powerbuilder"
            }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.powerbuilder",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.single.powerbuilder",
          "begin": "'",
          "end": "'|(?=$)",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.octal.powerbuilder",
          "match": "~o?\\d{3}"
        },
        {
          "name": "constant.character.escape.hex.powerbuilder",
          "match": "~h[0-9a-fA-F]{2}"
        },
        {
          "name": "constant.character.escape.powerbuilder",
          "match": "~."
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.powerbuilder",
          "match": "(?i)\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.powerbuilder",
          "match": "(?i)\\bfalse\\b"
        },
        {
          "name": "constant.language.null.powerbuilder",
          "match": "(?i)\\bnull\\b"
        }
      ]
    },

    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.date.powerbuilder",
          "match": "\\b\\d{4}-\\d{2}-\\d{2}\\b"
        },
        {
          "name": "constant.numeric.time.powerbuilder",
          "match": "\\b\\d{2}:\\d{2}:\\d{2}(\\.\\d+)?\\b"
        },
        {
          "name": "constant.numeric.float.powerbuilder",
          "match": "(?<![\\w$#%])[-+]?(\\d+\\.\\d*|\\.\\d+)([eE][-+]?\\d+)?(?![\\w$#%])"
        },
        {
          "name": "constant.numeric.integer.powerbuilder",
          "match": "(?<![\\w$#%\\.])[-+]?\\d+(?![\\w$#%\\.])"
        }
      ]
    },

    "enumerated-literal": {
      "patterns": [
        {
          "name": "constant.language.enumerated.powerbuilder",
          "match": "[A-Za-z_][\\w]*!"
        }
      ]
    },

    "datatypes": {
      "patterns": [
        {
          "name": "storage.type.primitive.powerbuilder",
          "match": "(?i)\\b(any|blob|boolean|byte|char|character|date|daterange|datetime|dec|decimal|double|int|integer|long|longlong|longptr|real|string|time|uint|ulong|unsignedint|unsignedinteger|unsignedlong|transaction|dynamicdescriptionarea|dynamicstagingarea|error|message|application|window|menu|datawindow|nonvisualobject|function_object)\\b"
        }
      ]
    },

    "pronouns": {
      "patterns": [
        {
          "name": "variable.language.powerbuilder",
          "match": "(?i)\\b(this|parent|super|sqlca|sqlda|sqlsa|error|message)\\b"
        }
      ]
    },

    "access-modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.access.powerbuilder",
          "match": "(?i)\\b(public|private|protected|privateread|privatewrite|protectedread|protectedwrite|systemread|systemwrite|global|shared|indirect|readonly|constant|ref|static)\\b"
        }
      ]
    },

    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.powerbuilder",
          "match": "(?i)\\b(if|then|else|elseif|end\\s+if|choose\\s+case|case|end\\s+choose|for|to|step|next|do|while|loop|until|exit|continue|call|goto|halt|return|try|catch|finally|end\\s+try|throw|throws|post|trigger|dynamic|release|end)\\b"
        }
      ]
    },

    "declaration-keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.powerbuilder",
          "match": "(?i)\\b(function|end\\s+function|subroutine|end\\s+subroutine|event|end\\s+event|on|end\\s+on|type|end\\s+type|within|from|forward|end\\s+forward|prototypes|end\\s+prototypes|variables|end\\s+variables|create|destroy|using|autoinstantiate|is|into|rpcfunc|alias|alias\\s+for|library|external|native|namespace|enumerated|intrinsic|system|static|open|close|procedure)\\b"
        }
      ]
    },

    "sql-keywords": {
      "patterns": [
        {
          "name": "keyword.other.sql.powerbuilder",
          "match": "(?i)\\b(select|selectblob|insert|update|updateblob|delete|commit|rollback|connect|disconnect|declare|cursor|procedure|execute|fetch|prepare|describe|descriptor|open|close|first|last|prior|immediate|set|values|where|from|into|of|current|using)\\b"
        }
      ]
    },

    "reserved-other": {
      "patterns": [
        {
          "name": "keyword.other.powerbuilder",
          "match": "(?i)\\b(and|or|not|xor|_debug|with)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.powerbuilder",
          "match": "<>|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.augmented.powerbuilder",
          "match": "\\+\\+|--|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.assignment.powerbuilder",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.powerbuilder",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "punctuation.separator.continuation.powerbuilder",
          "match": "&(?=\\s*$)"
        }
      ]
    },

    "forward-prototypes-section": {
      "name": "meta.prototypes.section.powerbuilder",
      "begin": "^\\s*(forward\\s+prototypes)\\b",
      "end": "^\\s*(end\\s+prototypes)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.declaration.powerbuilder"
        }
      },
      "endCaptures": {
        "1": {
          "name": "keyword.declaration.powerbuilder"
        }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#function-declaration" },
        { "include": "#event-declaration" },
        { "include": "#type-declaration" },
        { "include": "#global-object-declaration" },
        { "include": "#variable-declaration" },
        { "include": "#datatypes" },
        { "include": "#access-modifiers" },
        { "include": "#declaration-keywords" }
      ]
    },

    "prototypes-section": {
      "name": "meta.prototypes.section.powerbuilder",
      "begin": "^\\s*(prototypes)\\b",
      "end": "^\\s*(end\\s+prototypes)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.declaration.powerbuilder"
        }
      },
      "endCaptures": {
        "1": {
          "name": "keyword.declaration.powerbuilder"
        }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#function-declaration" },
        { "include": "#event-declaration" },
        { "include": "#type-declaration" },
        { "include": "#global-object-declaration" },
        { "include": "#variable-declaration" },
        { "include": "#datatypes" },
        { "include": "#access-modifiers" },
        { "include": "#declaration-keywords" }
      ]
    },

    "variables-section": {
      "name": "meta.variables.section.powerbuilder",
      "begin": "^\\s*((?:global\\s+variables|type\\s+variables|variables))\\b",
      "end": "^\\s*(end\\s+variables)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.declaration.variables.powerbuilder"
        }
      },
      "endCaptures": {
        "1": {
          "name": "keyword.declaration.variables.powerbuilder"
        }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#variable-declaration" },
        { "include": "#constants" },
        { "include": "#literals" },
        { "include": "#datatypes" },
        { "include": "#access-modifiers" },
        { "include": "#operators" }
      ]
    },

    "forward-section": {
      "name": "meta.forward.section.powerbuilder",
      "begin": "^\\s*(forward)\\b(?!\\s+prototypes\\b)",
      "end": "^\\s*(end\\s+forward)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.declaration.forward.powerbuilder"
        }
      },
      "endCaptures": {
        "1": {
          "name": "keyword.declaration.forward.powerbuilder"
        }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#type-declaration" },
        { "include": "#global-object-declaration" },
        { "include": "#declaration-keywords" },
        { "include": "#datatypes" },
        { "include": "#identifiers" }
      ]
    },

    "type-declaration": {
      "patterns": [
        {
          "name": "meta.type.declaration.powerbuilder",
          "match": "(?i)\\b((?:global|public|private|protected)\\s+)?(type)\\s+([A-Za-z_$#%][\\w$#%\\-]*)\\s+(from)\\s+([A-Za-z_$#%][\\w$#%\\-`]*)(?:\\s+(within)\\s+([A-Za-z_$#%][\\w$#%\\-`]*))?",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "keyword.declaration.powerbuilder" },
            "3": { "name": "entity.name.type.powerbuilder" },
            "4": { "name": "keyword.declaration.powerbuilder" },
            "5": { "name": "entity.other.inherited-class.powerbuilder" },
            "6": { "name": "keyword.declaration.powerbuilder" },
            "7": { "name": "entity.other.container.powerbuilder" }
          }
        }
      ]
    },

    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.declaration.powerbuilder",
          "match": "(?i)^\\s*((?:(?:public|private|protected|global|shared|static|rpcfunc|external|native|readonly|constant|ref|indirect)\\s+)*)function\\s+([A-Za-z_$#%][\\w$#%\\-`]*)\\s+([A-Za-z_$#%][\\w$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "entity.name.type.return.powerbuilder" },
            "3": { "name": "entity.name.function.powerbuilder" }
          }
        },
        {
          "name": "meta.subroutine.declaration.powerbuilder",
          "match": "(?i)^\\s*((?:(?:public|private|protected|global|shared|static|rpcfunc|external|native|readonly|constant|ref|indirect)\\s+)*)subroutine\\s+([A-Za-z_$#%][\\w$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "entity.name.function.powerbuilder" }
          }
        }
      ]
    },

    "event-declaration": {
      "patterns": [
        {
          "name": "meta.event.declaration.powerbuilder",
          "match": "(?i)^\\s*((?:(?:public|private|protected|global|shared|static)\\s+)*)event\\s+([A-Za-z_$#%][\\w$#%\\-]*(?:::[A-Za-z_$#%][\\w$#%\\-]*)?)\\s*(?:;|\\(|$)",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "entity.name.function.event.powerbuilder" }
          }
        }
      ]
    },

    "on-declaration": {
      "patterns": [
        {
          "name": "meta.event.on.powerbuilder",
          "match": "(?i)^\\s*(on)\\s+([A-Za-z_$#%][\\w$#%\\-]*(?:\\.[A-Za-z_$#%][\\w$#%\\-]*)+)\\s*;?\\s*$",
          "captures": {
            "1": { "name": "keyword.declaration.powerbuilder" },
            "2": { "name": "entity.name.function.event.powerbuilder" }
          }
        }
      ]
    },

    "global-object-declaration": {
      "patterns": [
        {
          "name": "meta.global.object.declaration.powerbuilder",
          "match": "(?i)^\\s*(global)\\s+(transaction|dynamicdescriptionarea|dynamicstagingarea|error|message|application|window|menu|datawindow|nonvisualobject|function_object)\\s+([A-Za-z_$#%][\\w$#%\\-]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "storage.type.primitive.powerbuilder" },
            "3": { "name": "variable.other.definition.powerbuilder" }
          }
        }
      ]
    },

    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.declaration.powerbuilder",
          "match": "^\\s*((?:(?:public|private|protected|global|shared|readonly|constant|ref|indirect|static)\\s+)*)((?:[A-Za-z_$#%][\\w$#%\\-`]*(?:\\{\\d+\\})?))\\s+([A-Za-z_$#%][\\w$#%\\-]*)",
          "captures": {
            "1": { "name": "storage.modifier.access.powerbuilder" },
            "2": { "name": "entity.name.type.powerbuilder" },
            "3": { "name": "variable.other.definition.powerbuilder" }
          }
        }
      ]
    },

    "sql-block": {
      "patterns": [
        {
          "name": "meta.sql.statement.powerbuilder",
          "begin": "(?i)^\\s*(select|selectblob|insert|update|updateblob|delete|declare|execute|fetch|prepare|open|close|commit|rollback|connect|disconnect|describe)\\b(?!\\s*\\()",
          "end": "(;)",
          "beginCaptures": {
            "1": { "name": "keyword.other.sql.powerbuilder" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.terminator.sql.powerbuilder" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#comments" },
            { "include": "#sql-inner-keywords" },
            { "include": "#literals" },
            { "include": "#constants" },
            { "include": "#operators" },
            {
              "name": "variable.other.sql.host.powerbuilder",
              "match": ":[A-Za-z_$#%][\\w$#%\\-]*"
            },
            {
              "name": "support.type.cursor.powerbuilder",
              "match": "(?i)\\b(cursor|descriptor)\\b"
            },
            {
              "name": "variable.other.sql.identifier.powerbuilder",
              "match": "[A-Za-z_$#%][\\w$#%\\-]*"
            }
          ]
        }
      ]
    },

    "sql-inner-keywords": {
      "patterns": [
        {
          "name": "keyword.other.sql.powerbuilder",
          "match": "(?i)\\b(select|selectblob|insert|update|updateblob|delete|from|into|where|values|set|commit|rollback|connect|disconnect|declare|cursor|procedure|execute|fetch|prepare|describe|descriptor|open|close|first|last|prior|next|immediate|current|of|using|for|and|or|not|xor|is|null|as|on|in|between|like|exists|having|group\\s+by|order\\s+by|union|all|distinct|dynamic|asc|desc)\\b"
        }
      ]
    },

    "support-functions": {
      "patterns": [
        {
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Abs|ACos|ASin|ATan|Ceiling|Cos|Exp|Fact|Log|LogTen|Max|Min|Mod|Pi|Rand|Randomize|Round|Sign|Sin|Sqrt|Tan|Truncate|String|Integer|Long|Double|Dec|Date|Time|Now|Today|Year|Month|Day|Hour|Minute|Second|Upper|Lower|Trim|Len|Pos|Right|Left|Mid|Replace|IsNull|IsValid|MessageBox|TriggerEvent|Create|Destroy|ClassName|UpperBound)\\s*(?=\\()"
        }
      ]
    },

    "ancestor-function-call": {
      "patterns": [
        {
          "name": "meta.function-call.ancestor.powerbuilder",
          "match": "([A-Za-z_$#%][\\w$#%\\-]*)(::)([A-Za-z_$#%][\\w$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "variable.language.powerbuilder" },
            "2": { "name": "punctuation.accessor.double-colon.powerbuilder" },
            "3": { "name": "entity.name.function.call.powerbuilder" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.powerbuilder",
          "match": "([A-Za-z_$#%][\\w$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.powerbuilder" }
          }
        }
      ]
    },

    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.powerbuilder",
          "match": "(?<=\\.)[A-Za-z_$#%][\\w$#%\\-]*"
        },
        {
          "name": "variable.other.member.ancestor.powerbuilder",
          "match": "(?<=::)[A-Za-z_$#%][\\w$#%\\-]*"
        }
      ]
    },

    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.powerbuilder",
          "match": "^[ \\t]*[A-Za-z_$#%][\\w$#%\\-]*:(?!:)"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.powerbuilder",
          "match": "[A-Za-z_$#%][\\w$#%\\-]*"
        }
      ]
    }
  }
}