{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src/client",
    "outDir": "out/client",
    "types": [
      "node",
      "vscode"
    ],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "out/.tsbuildinfo/client.tsbuildinfo"
  },
  "include": [
    "src/client/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ]
}