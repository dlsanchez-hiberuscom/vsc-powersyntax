{
  "name": "PowerBuilder",
  "scopeName": "source.powerbuilder",
  "fileTypes": [
    "sru", "srw", "srm", "sra", "srs", "srf", "srd",
    "srp", "srj", "srq"
  ],
  "firstLineMatch": "^((HA)?(?=\\$)|forward)",
  "patterns": [
    { "include": "#headers" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#sql-block" },
    { "include": "#type-declaration" },
    { "include": "#event-declaration" },
    { "include": "#function-declaration" },
    { "include": "#forward-declaration" },
    { "include": "#variable-section" },
    { "include": "#constants" },
    { "include": "#literals" },
    { "include": "#datatypes" },
    { "include": "#pronouns" },
    { "include": "#access-modifiers" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#sql-keywords" },
    { "include": "#reserved-other" },
    { "include": "#operators" },
    { "include": "#enumerated-literal" },
    { "include": "#support-functions" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "headers": {
      "patterns": [
        {
          "name": "meta.header.powerbuilder",
          "begin": "\\A(HA)?(?=\\$)",
          "end": "^(?!\\$)",
          "captures": {
            "1": { "name": "comment.block.documentation.headers.powerbuilder" }
          },
          "patterns": [
            {
              "name": "meta.header.line.powerbuilder",
              "match": "(\\$)(.*?)(\\$)(.*)",
              "captures": {
                "1": { "name": "comment.block.documentation.headers.powerbuilder" },
                "2": { "name": "variable.other.header.name.powerbuilder" },
                "3": { "name": "comment.block.documentation.headers.powerbuilder" },
                "4": {
                  "name": "string.unquoted.header.description.powerbuilder",
                  "patterns": [ { "include": "#string-escapes" } ]
                }
              }
            }
          ]
        }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.powerbuilder",
          "match": "//.*$"
        },
        {
          "name": "comment.block.powerbuilder",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.powerbuilder" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.powerbuilder" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.powerbuilder",
          "begin": "\"",
          "end": "\"",
          "patterns": [ { "include": "#string-escapes" } ]
        },
        {
          "name": "string.quoted.single.powerbuilder",
          "begin": "'",
          "end": "'|(?=$)",
          "patterns": [ { "include": "#string-escapes" } ]
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.octal.powerbuilder",
          "match": "~o?\\d{3}"
        },
        {
          "name": "constant.character.escape.hex.powerbuilder",
          "match": "~h[0-9a-fA-F]{2}"
        },
        {
          "name": "constant.character.escape.powerbuilder",
          "match": "~."
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.powerbuilder",
          "match": "(?i)\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.powerbuilder",
          "match": "(?i)\\bfalse\\b"
        },
        {
          "name": "constant.language.null.powerbuilder",
          "match": "(?i)\\bnull\\b"
        }
      ]
    },

    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.date.powerbuilder",
          "match": "\\b\\d{4}-\\d{2}-\\d{2}\\b"
        },
        {
          "name": "constant.numeric.time.powerbuilder",
          "match": "\\b\\d{2}:\\d{2}:\\d{2}(\\.\\d+)?\\b"
        },
        {
          "name": "constant.numeric.float.powerbuilder",
          "match": "(?<![\\w$#%])[-+]?(\\d+\\.\\d*|\\.\\d+)([eE][-+]?\\d+)?(?![\\w$#%])"
        },
        {
          "name": "constant.numeric.integer.powerbuilder",
          "match": "(?<![\\w$#%\\.])[-+]?\\d+(?![\\w$#%\\.])"
        }
      ]
    },

    "enumerated-literal": {
      "patterns": [
        {
          "name": "constant.language.enumerated.powerbuilder",
          "match": "[a-zA-Z_][\\w]*!"
        }
      ]
    },

    "datatypes": {
      "comment": "Official PB2022 standard datatypes + Any + daterange",
      "patterns": [
        {
          "name": "storage.type.primitive.powerbuilder",
          "match": "(?i)\\b(any|blob|boolean|byte|char|character|date|daterange|datetime|dec|decimal|double|int|integer|long|longlong|longptr|real|string|time|uint|ulong|unsignedint|unsignedinteger|unsignedlong)\\b"
        }
      ]
    },

    "pronouns": {
      "comment": "Official PB2022 pronouns: this, parent, super + transaction globals",
      "patterns": [
        {
          "name": "variable.language.powerbuilder",
          "match": "(?i)\\b(this|parent|super|sqlca|sqlda|sqlsa|error|message)\\b"
        }
      ]
    },

    "access-modifiers": {
      "comment": "Official PB2022 access/scope modifiers",
      "patterns": [
        {
          "name": "storage.modifier.access.powerbuilder",
          "match": "(?i)\\b(public|private|protected|privateread|privatewrite|protectedread|protectedwrite|systemread|systemwrite|global|shared|indirect|readonly|constant|ref)\\b"
        }
      ]
    },

    "control-keywords": {
      "comment": "Official PB2022 control flow statements + standalone end",
      "patterns": [
        {
          "name": "keyword.control.powerbuilder",
          "match": "(?i)\\b(if|then|else|elseif|end\\s+if|choose\\s+case|case|end\\s+choose|for|to|step|next|do|while|loop|until|exit|continue|call|goto|halt|return|try|catch|finally|end\\s+try|throw|throws|post|trigger|dynamic|release|end)\\b"
        }
      ]
    },

    "declaration-keywords": {
      "comment": "Official PB2022 declaration/structure keywords",
      "patterns": [
        {
          "name": "keyword.declaration.powerbuilder",
          "match": "(?i)\\b(function|end\\s+function|subroutine|end\\s+subroutine|event|end\\s+event|on|end\\s+on|type|end\\s+type|within|from|forward|end\\s+forward|prototypes|end\\s+prototypes|variables|end\\s+variables|create|destroy|using|autoinstantiate|is|into|rpcfunc|alias|alias\\s+for|library|external|native|namespace|enumerated|intrinsic|system|static|open|close|procedure)\\b"
        }
      ]
    },

    "sql-keywords": {
      "comment": "SQL-related reserved words used in embedded SQL",
      "patterns": [
        {
          "name": "keyword.other.sql.powerbuilder",
          "match": "(?i)\\b(select|selectblob|insert|update|updateblob|delete|commit|rollback|connect|disconnect|declare|cursor|procedure|execute|fetch|prepare|describe|descriptor|open|close|first|last|prior|immediate|set|values|where|from|into|of|current|using)\\b"
        }
      ]
    },

    "reserved-other": {
      "comment": "Remaining official reserved words not covered above",
      "patterns": [
        {
          "name": "keyword.other.powerbuilder",
          "match": "(?i)\\b(and|or|not|xor|_debug|with)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.powerbuilder",
          "match": "<>|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.augmented.powerbuilder",
          "match": "\\+\\+|--|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.assignment.powerbuilder",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.powerbuilder",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "keyword.operator.concatenation.powerbuilder",
          "match": "&\\s*$",
          "comment": "Line continuation character"
        }
      ]
    },

    "type-declaration": {
      "comment": "TYPE name FROM ancestor WITHIN container",
      "patterns": [
        {
          "name": "meta.type.declaration.powerbuilder",
          "match": "(?i)\\b(type)\\s+([\\w$#%][\\w\\d$#%\\-]*)\\s+(from)\\s+([\\w$#%][\\w\\d$#%\\-`]*)(\\s+(within)\\s+([\\w$#%][\\w\\d$#%\\-`]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.powerbuilder" },
            "2": { "name": "entity.name.type.powerbuilder" },
            "3": { "name": "keyword.declaration.powerbuilder" },
            "4": { "name": "entity.other.inherited-class.powerbuilder" },
            "6": { "name": "keyword.declaration.powerbuilder" },
            "7": { "name": "entity.other.inherited-class.powerbuilder" }
          }
        }
      ]
    },

    "event-declaration": {
      "comment": "EVENT keyword followed by optional type clause and event name",
      "patterns": [
        {
          "name": "meta.event.declaration.powerbuilder",
          "match": "(?i)\\b(event)(\\s+(type)\\s+([\\w$#%][\\w\\d$#%\\-`]*))?\\s+([\\w$#%][\\w\\d$#%\\-]*)\\s*(?=\\(|;|$)",
          "captures": {
            "1": { "name": "keyword.declaration.powerbuilder" },
            "3": { "name": "keyword.declaration.powerbuilder" },
            "4": { "name": "storage.type.primitive.powerbuilder" },
            "5": { "name": "entity.name.function.event.powerbuilder" }
          }
        }
      ]
    },

    "function-declaration": {
      "comment": "FUNCTION/SUBROUTINE return_type name (...)",
      "patterns": [
        {
          "name": "meta.function.declaration.powerbuilder",
          "match": "(?i)\\b(function|subroutine)\\s+([\\w$#%][\\w\\d$#%\\-`]*)\\s+([\\w$#%][\\w\\d$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.powerbuilder" },
            "2": {
              "patterns": [
                { "include": "#datatypes" },
                {
                  "name": "entity.name.type.return.powerbuilder",
                  "match": "[\\w$#%][\\w\\d$#%\\-`]*"
                }
              ]
            },
            "3": { "name": "entity.name.function.powerbuilder" }
          }
        }
      ]
    },

    "forward-declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.forward.powerbuilder",
          "match": "(?i)\\b(forward|end\\s+forward)\\b"
        }
      ]
    },

    "variable-section": {
      "patterns": [
        {
          "name": "keyword.declaration.variables.powerbuilder",
          "match": "(?i)\\b(variables|end\\s+variables)\\b"
        }
      ]
    },

    "sql-block": {
      "comment": "Embedded SQL statement blocks ending with ;",
      "patterns": [
        {
          "name": "meta.sql.statement.powerbuilder",
          "begin": "(?i)^\\s*(select|selectblob|insert|update|updateblob|delete|declare|execute|fetch|prepare|open|close|commit|rollback|connect|disconnect|describe)\\b(?!\\s*\\()",
          "end": "(;)",
          "beginCaptures": {
            "1": { "name": "keyword.other.sql.powerbuilder" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.terminator.sql.powerbuilder" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#comments" },
            { "include": "#sql-inner-keywords" },
            { "include": "#literals" },
            { "include": "#constants" },
            { "include": "#operators" },
            {
              "name": "variable.other.sql.host.powerbuilder",
              "match": ":[\\w$#%][\\w\\d$#%\\-]*"
            },
            {
              "name": "variable.other.local.powerbuilder",
              "match": "[\\w$#%][\\w\\d$#%\\-]*"
            }
          ]
        }
      ]
    },

    "sql-inner-keywords": {
      "patterns": [
        {
          "name": "keyword.other.sql.powerbuilder",
          "match": "(?i)\\b(select|selectblob|insert|update|updateblob|delete|from|into|where|values|set|commit|rollback|connect|disconnect|declare|cursor|procedure|execute|fetch|prepare|describe|descriptor|open|close|first|last|prior|next|immediate|current|of|using|for|and|or|not|xor|is|null|as|on|in|between|like|exists|having|group\\s+by|order\\s+by|union|all|distinct|dynamic|asc|desc)\\b"
        }
      ]
    },

    "support-functions": {
      "comment": "Official PB2025 PowerScript built-in global/system functions",
      "patterns": [
        {
          "comment": "Math functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Abs|ACos|ASin|ATan|Ceiling|Cos|Exp|Fact|Log|LogTen|Max|Min|Mod|Pi|Rand|Randomize|Round|Sign|Sin|Sqrt|Tan|Truncate)\\s*(?=\\()"
        },
        {
          "comment": "String functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Asc|AscA|CharA|Fill|FillA|LastPos|LastPosA|Left|LeftA|LeftTrim|Len|LenA|Length|Lower|LowerBound|Match|Mid|MidA|Pos|PosA|Replace|ReplaceA|Reverse|Right|RightA|RightTrim|Space|Trim|Upper|UpperBound|WordCap)\\s*(?=\\()"
        },
        {
          "comment": "Date/Time functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Day|DayName|DayNumber|DaysAfter|Hour|Minute|Month|Now|RelativeDate|RelativeTime|Second|SecondsAfter|Today|Year)\\s*(?=\\()"
        },
        {
          "comment": "File I/O and directory functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(FileClose|FileCopy|FileDelete|FileEncoding|FileExists|FileLength|FileLength64|FileMove|FileOpen|FileRead|FileReadEx|FileSeek|FileSeek64|FileWrite|FileWriteEx|CreateDirectory|DirectoryExists|RemoveDirectory|ChangeDirectory|DirList|DirSelect)\\s*(?=\\()"
        },
        {
          "comment": "System and utility functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Beep|BlobEdit|BlobMid|ChangeMenu|ChooseColor|ClassList|ClassName|Clipboard|CloseWithReturn|CommandParm|Compress|ConnectToNewObject|ConnectToObject|Cpu|CreateInstance|DBHandle|DebugBreak|DisableCommit|DisconnectObject|DisconnectServer|EnableCommit|GarbageCollect|GarbageCollectGetTimeLimit|GarbageCollectSetTimeLimit|GetApplication|GetContextService|GetCurrentDirectory|GetEnvironment|GetFileOpenName|GetFileSaveName|GetFocus|Handle|Idle|IntHigh|IntLow|IsDate|IsNull|IsNumber|IsTime|IsValid|KeyDown|MessageBox|PixelsToUnits|PointerX|PointerY|PopMenu|PopulateError|PostEvent|Restart|RGB|Run|SetAbort|SetComplete|SetNull|SetPointer|SetProfileString|SetTransPool|ShowHelp|ShowPopupHelp|SignalError|Sleep|SyntaxFromSQL|Timer|ToAnsi|ToUnicode|TriggerEvent|TypeOf|UnitsToPixels|Which|Yield)\\s*(?=\\()"
        },
        {
          "comment": "Library functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(AddToLibraryList|GetLibraryList|LibraryCreate|LibraryDelete|LibraryDirectory|LibraryDirectoryEx|LibraryExport|LibraryImport|SetLibraryList)\\s*(?=\\()"
        },
        {
          "comment": "Registry functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(RegistryDelete|RegistryGet|RegistryKeys|RegistrySet|RegistryValues)\\s*(?=\\()"
        },
        {
          "comment": "Shared object functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(SharedObjectDirectory|SharedObjectGet|SharedObjectRegister|SharedObjectUnregister)\\s*(?=\\()"
        },
        {
          "comment": "Window/sheet management functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(OpenSheet|OpenSheetAsDocument|OpenSheetDocked|OpenSheetFromDockingState|OpenSheetInTabGroup|OpenSheetWithParm|OpenSheetWithParmAsDocument|OpenSheetWithParmDocked|OpenSheetWithParmFromDockingState|OpenSheetWithParmInTabGroup|OpenTab|OpenTabWithParm|OpenUserObject|OpenUserObjectWithParm|OpenWithParm|ParentWindow)\\s*(?=\\()"
        },
        {
          "comment": "Print functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(Print|PrintBitmap|PrintCancel|PrintClose|PrintDataWindow|PrintDefineFont|PrintEx|PrintGetPrinter|PrintGetPrinters|PrintLine|PrintOpen|PrintOval|PrintPage|PrintRect|PrintRoundRect|PrintScreen|PrintSetFont|PrintSetPrinter|PrintSetSpacing|PrintSetup|PrintSetupPrinter|PrintText|PrintWidth|PrintX|PrintY|ProfileInt|ProfileString)\\s*(?=\\()"
        },
        {
          "comment": "Trace functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(TraceBegin|TraceClose|TraceDisableActivity|TraceEnableActivity|TraceEnd|TraceError|TraceOpen|TraceUser)\\s*(?=\\()"
        },
        {
          "comment": "Cryptography and encoding functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(AsymmetricDecrypt|AsymmetricEncrypt|AsymmetricGenerateKey|AsymmetricSign|AsymmetricVerifySign|Base32Decode|Base32Encode|Base64Decode|Base64Encode|Base64UrlDecode|Base64UrlEncode|FromAnsi|FromUnicode|HexDecode|HexEncode|HMAC|MD5|SHA|SymmetricDecrypt|SymmetricEncrypt|SymmetricGenerateKey|UrlDecode|UrlEncode)\\s*(?=\\()"
        },
        {
          "comment": "XML and workspace functions",
          "name": "support.function.powerbuilder",
          "match": "(?i)\\b(XMLParseFile|XMLParseString|WorkSpaceHeight|WorkSpaceWidth|WorkSpaceX|WorkSpaceY)\\s*(?=\\()"
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.powerbuilder",
          "match": "([\\w$#%][\\w\\d$#%\\-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.powerbuilder" }
          }
        }
      ]
    },

    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.powerbuilder",
          "match": "(?<=::|\\.)[\\w$#%][\\w\\d$#%\\-]*"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.powerbuilder",
          "match": "[\\w$#%][\\w\\d$#%\\-]*"
        }
      ]
    }
  }
}
